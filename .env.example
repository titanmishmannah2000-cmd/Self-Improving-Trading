# ─────────────────────────────────────────────────────────────────────────────
# HERMES TRADING — ENVIRONMENT VARIABLES TEMPLATE (single source of truth)
# ─────────────────────────────────────────────────────────────────────────────
# This file is COMMITTED (placeholders only) so every key the system reads is
# documented in ONE place. Copy it to `.env` and fill in real values:
#
#     cp .env.example .env
#     # then edit .env with your real keys
#
# `.env` is git-ignored (never committed) — it holds the REAL secrets.
# Code reads both via load_dotenv() (hermes_core/env.py), so local runs and
# Railway deploys pull from the same file.
#
# DEPLOY: at deploy time, ingest this same file into Railway's vault once:
#     railway variables --from .env
# (Railway then holds the encrypted copies; the file stays local/git-ignored.
#  You set keys ONCE, here — never twice.)
# ─────────────────────────────────────────────────────────────────────────────

# ── Price feed backend selection ──────────────────────────────────────────────
# "aggregate" (default, multi-source real quotes) | "yfinance" | "http"
PRICE_BACKEND=aggregate

# ── Hermes Price Aggregator sources (backend=aggregate) ────────────────────────
# Alpha Vantage — FX cross-check (free tier, ~15min delayed, rate-limited)
ALPHA_VANTAGE_KEY=
# metals.dev — XAU/USD + XAG/USD (your subscription; covers BOTH gold + silver)
METALS_API_KEY=

# ── httpx REST backend (backend=http, opt-in) ─────────────────────────────────
PRICE_API_URL=
PRICE_API_KEY=

# ── websockets stream backend (opt-in) ────────────────────────────────────────
PRICE_WS_URL=
PRICE_WS_API_KEY=

# ── LLM reflection (gemini_reflection engine) ─────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Discord alerts (stdlib webhook POST, fail-soft) ────────────────────────────
DISCORD_ALERTS_WEBHOOK=
DISCORD_REFLECTIONS_WEBHOOK=
DISCORD_DAILY_WEBHOOK=

# ── Runtime / deploy ──────────────────────────────────────────────────────────
HERMES_BOT_NAME=forex
DASHBOARD_API_URL=
# Shared secret between bots (price/trade pushers) and the dashboard ingest API.
# Must be IDENTICAL on both sides. Empty -> dashboard rejects all ingests. [L64]
INGEST_TOKEN=
# Poll interval between cycles, seconds (loop is poll-based)
HERMES_CYCLE_SECONDS=60
