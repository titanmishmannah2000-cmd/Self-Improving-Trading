# ─────────────────────────────────────────────────────────────────────────────
# HERMES TRADING — ENVIRONMENT VARIABLES TEMPLATE (single source of truth)
# ─────────────────────────────────────────────────────────────────────────────
# This file is COMMITTED (placeholders only) so every key the system reads is
# documented in ONE place. Copy it to `.env` and fill in real values:
#
#     cp .env.example .env
#     # then edit .env with your real keys
#
# `.env` is git-ignored (never committed) — it holds the REAL secrets.
# Code reads both via load_dotenv() (hermes_core/env.py), so local runs and
# Railway deploys pull from the same file.
#
# DEPLOY: at deploy time, ingest this same file into Railway's vault once:
#     railway variables --from .env
# (Railway then holds the encrypted copies; the file stays local/git-ignored.
#  You set keys ONCE, here — never twice.)
# ─────────────────────────────────────────────────────────────────────────────

# ── Price feed backend selection ──────────────────────────────────────────────
# "aggregate" (default, multi-source real quotes) | "yfinance" | "http"
PRICE_BACKEND=aggregate

# ── Hermes Price Aggregator sources (backend=aggregate) ────────────────────────
# Alpha Vantage — FX cross-check (free tier, ~15min delayed, rate-limited)
ALPHA_VANTAGE_KEY=
# metals.dev — XAU/USD + XAG/USD (your subscription; covers BOTH gold + silver)
METALS_API_KEY=

# ── httpx REST backend (backend=http, opt-in) ─────────────────────────────────
PRICE_API_URL=
PRICE_API_KEY=

# ── websockets stream backend (opt-in) ────────────────────────────────────────
PRICE_WS_URL=
PRICE_WS_API_KEY=

# ── LLM reflection (gemini_reflection engine) ─────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Discord alerts (stdlib webhook POST, fail-soft) ────────────────────────────
DISCORD_ALERTS_WEBHOOK=
DISCORD_REFLECTIONS_WEBHOOK=
DISCORD_DAILY_WEBHOOK=

# ── Runtime / deploy ──────────────────────────────────────────────────────────
HERMES_BOT_NAME=forex
DASHBOARD_API_URL=
# Shared secret between bots (price/trade pushers) and the dashboard ingest API.
# Must be IDENTICAL on both sides. Empty -> dashboard rejects all ingests. [L64]
INGEST_TOKEN=
# Poll interval between cycles, seconds (loop is poll-based)
HERMES_CYCLE_SECONDS=60

# ── HIF Phase-1 probe sizing ──────────────────────────────────────────────────
# "1" = open at 25% size when cortex has <5 closed outcomes for (pair, entry_type).
# "0" / unset = full size always (legacy behavior). Never blocks trades.
# Rollback: set PROBE_SIZING=0 and restart bots.
PROBE_SIZING=0

# ── HIF Phase-2 soft expert weights ───────────────────────────────────────────
# "1" = L35 policy benches shrink size (soft) instead of skipping the trade.
# Under-sampled experts keep an explore floor so learning continues.
# "0" / unset = hard policy_suppress skips (legacy). Rollback: SOFT_WEIGHTS=0.
SOFT_WEIGHTS=0

# ── HIF Phase-3 soft regime size multiplier ───────────────────────────────────
# "1" = scale size by trend/range + short direction (never blocks).
# "0" / unset = no extra regime mult (legacy). Rollback: REGIME_SIZING=0.
REGIME_SIZING=0

# ── HIF Phase-4 skip + GP-shadow reflection fuel ──────────────────────────────
# "1" = log shadow hypotheses from skips/gp_shadow when pairs are quiet;
#       also attach skip context to trade-based reflection. Never auto-deploys.
# "0" / unset = close-only reflection (legacy). Rollback: SKIP_SHADOW_REFLECT=0.
SKIP_SHADOW_REFLECT=0

# ── HIF Phase-5 Bayesian fractional Kelly ─────────────────────────────────────
# "1" = scale size by quarter-Kelly from cortex Beta WR + payoff odds.
# No evidence → passthrough. Never blocks. Rollback: KELLY_SIZING=0.
KELLY_SIZING=0

# ── HIF Layer B entry ranking ─────────────────────────────────────────────────
# "1" = when traditional and GP both fire, open the higher expected-edge score.
# Still opens if only one candidate. Never hard-blocks. Rollback: ENTRY_RANKING=0.
ENTRY_RANKING=0

# ── HIF exit intelligence ─────────────────────────────────────────────────────
# "1" = stamp trail / BE / partial knobs from cortex per pair (same fills).
# Thin evidence → passthrough. Rollback: EXIT_INTEL=0.
EXIT_INTEL=0

# ── HIF skip-shadow promote (gated) ───────────────────────────────────────────
# "1" = auto-backtest deployable skip_shadow_proposed (e.g. RR TP fix).
# Never blind — backtest must pass; REFLECT_AUTO_DEPLOY gates YAML write.
# Rollback: SKIP_SHADOW_PROMOTE=0.
SKIP_SHADOW_PROMOTE=0

# ── HIF book-level risk ───────────────────────────────────────────────────────
# "1" = soft-cap total open size + tilt new size by posterior edge vs book.
# Never blocks. Rollback: BOOK_RISK=0.
BOOK_RISK=0

# ── HIF MFE/MAE peak tracking ─────────────────────────────────────────────────
# "1" (default) = log peak favourable / adverse unrealised % + giveback/capture
# on close into cortex + trade raw_json (excursion scoreboard). Peaks always
# update live for mfe_giveback exits regardless of this flag.
# Rollback: MFE_TRACKING=0 (omit excursion fields on close logs only).
MFE_TRACKING=1

# ── HIF momentum range / confluence guard (Jul 23 gold lesson) ────────────────
# "1" = force on for all bots. "0" = force off.
# Unset = auto-on for gold only: bench rsi_momentum in range unless both metals
# oversold or GP agrees; otherwise probe-size until confluence. Never blocks GP.
# Rollback: MOM_RANGE_GUARD=0.
# MOM_RANGE_GUARD=

# ── GP Brain promote + invent profiles ───────────────────────────────────────
# "1" = allow GP ensemble as real paper entries when the promote gate says so.
# GP_PROMOTE=
# Comma list seeds initial per-pair bans in gp_promote_gate.json (cold start).
# Invent/shadow keep running on banned pairs; only promote entries are blocked.
# Gate auto ban/unban from paper/shadow expectancy (min samples + hysteresis +
# cooldown). Defaults: MIN_SAMPLES=30 BAN=-0.05 UNBAN=0.05 COOLDOWN_S=86400.
# GP_EXCLUDE_PAIRS=GBP/JPY,BTC/USD
# GP_PROMOTE_GATE_MIN_SAMPLES=30
# GP_PROMOTE_GATE_BAN=-0.05
# GP_PROMOTE_GATE_UNBAN=0.05
# GP_PROMOTE_GATE_COOLDOWN_S=86400
#
# Per-bot invent (TF + horizon + size + timeout) lives in bots/*/config.yaml
# under `invent:` — forex daily/h10, gold daily/h20, crypto 1h/h12 (smaller
# search, longer timeout). Invent TF must equal live GP eval TF.
